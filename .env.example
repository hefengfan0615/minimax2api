# MiniMax2API Configuration
# Copy to .env and fill in your values. Env vars override config.json.

# Server port
PORT=8000

# Your MiniMax API key (from https://platform.minimax.io)
MINIMAX_API_KEY=

# MiniMax API Base URL
# International: https://api.minimax.io/v1
# China:         https://api.minimaxi.com/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Default model for requests
DEFAULT_MODEL=MiniMax-M2.7

# Comma-separated proxy API keys that clients use to access this proxy
PROXY_API_KEYS=sk-default

# ═══════════════════════════════════════════════════════════════
# For multi-account support, add accounts via the WebUI at
# http://localhost:<PORT>/admin/ or edit config.json manually.
# ═══════════════════════════════════════════════════════════════
